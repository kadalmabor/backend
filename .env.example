# General Server Config
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database Configuration (MongoDB)
MONGO_URI=mongodb://localhost:27017/evoting

# Admin Credentials (For Database Seeding)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Admin Blockchain Identity (contract owner — used by backend to mint Student NFT)
# Local Hardhat account #0 (well-known dev key — never use on mainnet):
# ADMIN_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
ADMIN_ADDRESS=
ADMIN_PRIVATE_KEY=

# Verifiable Credential (VC) Issuer signing key (32-byte hex). For local dev you may reuse
# the same key as ADMIN_PRIVATE_KEY; use a dedicated key in production.
VC_ISSUER_PRIVATE_KEY=

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Blockchain Configuration
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
VOTING_SYSTEM_ADDRESS=
