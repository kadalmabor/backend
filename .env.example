# General Server Config
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database Configuration (MongoDB)
MONGO_URI=mongodb://localhost:27017/evoting

# Admin Credentials (For Database Seeding)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Admin Blockchain Identity (For Deployment & Ownership)
# public key
ADMIN_ADDRESS=
# private key
ADMIN_PRIVATE_KEY=

# Verifiable Credential (VC) Issuer
# Trusted authority for signing VCs
VC_ISSUER_PRIVATE_KEY=

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Blockchain Configuration
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
VOTING_SYSTEM_ADDRESS=
